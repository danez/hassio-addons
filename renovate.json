{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:pinDigests",
    ":configMigration",
    "helpers:pinGitHubActionDigests"
  ],
  "packageRules": [
    {
      "matchFileNames": ["**/Dockerfile", "**/build.yaml"],
      "extends": [":semanticCommitTypeAll(fix)"]
    },
    {
      "matchDepNames": ["libpq", "postgresql**"],
      "groupName": "postgresql"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update apk packages in Dockerfiles",
      "managerFilePatterns": ["/(^|/)Dockerfile$/"],
      "matchStrings": [
        "\\s{2}(?<depName>\\S+?)=(?<currentValue>[0-9.-_a-zA-Z]+?)(\\s\\\\)?\\n"
      ],
      "datasourceTemplate": "repology",
      "packageNameTemplate": "alpine_3_23/{{{depName}}}",
      "versioningTemplate": "loose"
    },
    {
      "customType": "regex",
      "description": "Update restic",
      "managerFilePatterns": ["//Dockerfile$/"],
      "matchStrings": ["RESTIC_VERSION=(?<currentValue>.+?)\\n"],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "restic",
      "packageNameTemplate": "restic/restic",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "Update resticprofile",
      "managerFilePatterns": ["//Dockerfile$/"],
      "matchStrings": ["RESTICPROFILE_VERSION=(?<currentValue>.+?)\\n"],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "resticprofile",
      "packageNameTemplate": "creativeprojects/resticprofile",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "Update rclone",
      "managerFilePatterns": ["//Dockerfile$/"],
      "matchStrings": ["RCLONE_VERSION=(?<currentValue>.+?)\\n"],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "rclone",
      "packageNameTemplate": "rclone/rclone",
      "versioningTemplate": "semver"
    }
  ]
}
